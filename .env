# CloudMoon Web Server Configuration
NODE_ENV=development
PORT=3000

# API Configuration
API_BASE_URL=https://api.cloudmoonapp.com
API_TIMEOUT=30000

# Database (if needed)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudmoon
DB_USER=cloudmoon
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production

# CORS Configuration
CORS_ORIGIN=*

# Server Configuration
WORKERS=4
ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080,https://cloudmoonapp.com

# Logging
LOG_LEVEL=info
